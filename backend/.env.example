# Little Alphaxiv backend — CORS proxy + per-user persistence + auth
#
# Copy to .env and adjust if needed.

# --- PDF disk cache (existing) ---
# Where to cache downloaded arXiv PDFs (disk cache, keyed by arxiv id).
# Default: ~/.little_alphaxiv/pdf_cache
# LAX_PDF_CACHE=/path/to/cache

# --- Persistence + auth (added) ---
# SQLite database file. Default: backend/little_alphaxiv.db
LAX_DATABASE_URL=sqlite:///./little_alphaxiv.db

# Secret key for encrypting stored API keys at rest (Fernet) AND signing session
# cookies (itsdangerous). REQUIRED in production. If absent on first run, the
# server generates one and writes it to backend/.env, then refuses to start
# again without it (so a generated key isn't silently rotated, which would
# orphan all encrypted keys and all sessions). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LAX_SECRET_KEY=

# Cookie secure flag. False for LAN http (default); True behind https.
LAX_SECURE_COOKIES=false

# Allowed browser origins for CORS (comma-separated). With credentials, "*" is
# illegal — must enumerate. Dev: the Vite proxy origin.
LAX_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Session lifetime in days.
LAX_SESSION_MAX_AGE_DAYS=30

# Host/port are set on the command line in run.sh / run.bat.
